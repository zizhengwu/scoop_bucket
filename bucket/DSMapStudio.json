{
    "version": "1.11.1",
    "description": "A modding tool for the Dark Souls series.",
    "homepage": "https://github.com/soulsmods/DSMapStudio",
    "license": "GPL-3.0",
    "url": "https://github.com/soulsmods/DSMapStudio/releases/download/release-1.11.1/DSMapStudio-1.11.1.hotfix3.zip",
    "hash": "e66fce9ca3c0f24f9e69087920be4e66eee579ff8c480571a97ec5549c11a1ac",
    "bin": "DSMapStudio.exe",
    "shortcuts": [
        [
            "DSMapStudio.exe",
            "DSMapStudio"
        ]
    ],
    "checkver": {
        "script": [
            "$content = (Invoke-WebRequest 'https://github.com/soulsmods/DSMapStudio/releases' -UseBasicParsing).Content",
            "if ($content -match '/soulsmods/DSMapStudio/releases/tag/(release-[\\d.]+)') {",
            "    (Invoke-WebRequest \"https://github.com/soulsmods/DSMapStudio/releases/expanded_assets/$($matches[1])\" -UseBasicParsing).Content",
            "}"
        ],
        "regex": "DSMapStudio-(?<version>[\\d.]+)(?<suffix>(?:\\.[\\w-]+)*)\\.zip"
    },
    "autoupdate": {
        "url": "https://github.com/soulsmods/DSMapStudio/releases/download/release-$version/DSMapStudio-$version$matchSuffix.zip"
    }
}
